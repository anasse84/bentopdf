# Configuration pour la sécurité WebAssembly (Indispensable pour le multithreading)
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

# Optimisation et Type MIME pour les fichiers WASM
/*.wasm
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/wasm

# Configuration spécifique pour les fichiers compressés sur R2/Pages
/*.wasm.gz
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/wasm
  Content-Encoding: gzip

/*.data.gz
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/octet-stream
  Content-Encoding: gzip

# Pas de cache pour le Service Worker pour permettre les mises à jour
/sw.js
  Cache-Control: no-cache
